# ========================================
# Paimon 配置文件
# ========================================
# 复制此文件为 .env 并填入实际配置
# 切换 LLM Provider 只需修改 LLM_PROVIDER

# ========== LLM Provider 选择 ==========
# 选项: "claude-xiaomi" | "claude-official" | "openai" |
#       "deepseek-pro" | "deepseek-flash"
# 典型 DeepSeek 分层：
#   LLM_PROVIDER="deepseek-flash"      # shallow 池（闲聊/压缩/标题）
#   LLM_DEEP_PROVIDER="deepseek-pro"   # deep 池（Agent/DAG/复杂任务）
LLM_PROVIDER="claude-xiaomi"
# 深层池 Provider (复杂任务)，留空则同 LLM_PROVIDER
LLM_DEEP_PROVIDER=""
GNOSIS_SHALLOW_CONCURRENCY=5
GNOSIS_DEEP_CONCURRENCY=2

# ========== Claude 小米内网配置 ==========
CLAUDE_XIAOMI_API_KEY=""
CLAUDE_XIAOMI_BASE_URL="http://model.mify.ai.srv/anthropic"
CLAUDE_XIAOMI_MODEL="ppio/pa/claude-opus-4-6"

# ========== Claude 官方 API 配置 ==========
CLAUDE_OFFICIAL_API_KEY=""
CLAUDE_OFFICIAL_BASE_URL="https://api.anthropic.com"
CLAUDE_OFFICIAL_MODEL="claude-opus-4-6"

# ========== OpenAI 配置 ==========
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4"

# ========== DeepSeek 配置（OpenAI 兼容，pro / flash 双档）==========
# api_key + base_url 共享；model + thinking 各自独立。
# 文档：https://api-docs.deepseek.com/zh-cn/guides/thinking_mode
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
# pro：强推理 / 适合 deep pool（默认开 thinking）
DEEPSEEK_PRO_MODEL="deepseek-v4-pro"
DEEPSEEK_PRO_THINKING=true
# flash：轻量 / 适合 shallow pool（默认关 thinking，省成本）
DEEPSEEK_FLASH_MODEL="deepseek-v4-flash"
DEEPSEEK_FLASH_THINKING=false
# thinking 开启时生效；DeepSeek 有效值仅 "high" / "max"
DEEPSEEK_REASONING_EFFORT="high"

# ========== MiMo 配置 (音视频理解) ==========
MIMO_KEY=""
MIMO_BASE_URL="https://api.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2-pro"

# ========== WebUI 配置 ==========
WEBUI_ENABLED=true
WEBUI_HOST="0.0.0.0"
WEBUI_PORT=2975
WEBUI_ACCESS_CODE=""

# ========== Telegram 配置 ==========
BOT_TOKEN=""
OWNER_ID=0

# ========== QQ 配置 ==========
QQ_APPID=""
QQ_SECRET=""
QQ_OWNER_IDS=""

# ========== 系统配置 ==========
DEBUG=false
STREAM_INTERVAL=1.0
MAX_TOKENS=64000
CONTEXT_WINDOW_TOKENS=128000
CONTEXT_COMPRESS_THRESHOLD_PCT=75.0
CONTEXT_KEEP_RECENT_MESSAGES=12
